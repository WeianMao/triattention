# ============================================================================

# Version Control
.git/
.svn/
.hg/

# OS Files
.DS_Store
Thumbs.db
*.tmp
*.swp
*~

# IDE Files
.vscode/
.idea/
.vs/
*.sublime-*

# Logs
*.log
logs/

# ============================================================================
# Python (Detected: setup.py, pyproject.toml, requirements.txt, *.py files)
# ============================================================================

__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
.env/
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
*.egg
dist/
build/
.eggs/
.mypy_cache/
.ruff_cache/
.tox/
.nox/

# ============================================================================
# Node.js (Detected: package.json)
# ============================================================================

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/
package-lock.json
yarn.lock
pnpm-lock.yaml
.pnpm-store/

# ============================================================================
# Docker (Detected: Dockerfile)
# ============================================================================

.dockerignore
docker-compose.override.yml
*.tar

# ============================================================================
# Project-Specific Rules
# ============================================================================

# Backup directories
R-KV-backup-*/

# Output directories (symlinks)
outputs/

# Large data files
*.jsonl
*.json.gz
*.pt
*.bin
*.safetensors
*.ckpt

# HuggingFace cache
.cache/

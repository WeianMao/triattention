{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Debug Llama Evaluation",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/evaluation.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "CUDA_VISIBLE_DEVICES": "0"
            },
            "args": [
                "--output-dir", "outputs/DeepSeek-R1-Distill-Llama-8B/gpqa",
                "--model-path", "/root/autodl-tmp/model/DeepSeek-R1-Distill-Llama-8B",
                "--tokenizer-path", "/root/autodl-tmp/model/DeepSeek-R1-Distill-Llama-8B",
                "--model-size", "7b",
                "--model-type", "llama3",
                "--data-type", "test",
                "--max_num_examples", "100000000000000",
                "--max_new_tokens", "2048",
                "--eval_batch_size", "1",
                "--temperature", "0.0",
                "--seed", "42",
                "--benchmark", "commonsense_qa",
                "--method", "SCISSORHANDS",
                "--use_cache", "True",
                "--max_kv_capacity", "192",
                "--decoding_recent_size", "25",
                "--attn_implementation", "eager"
            ]
        }
    ]
}